{
  "manifest_version": 2,
  "name": "Proxy Browser",
  "version": "0.1.0",
  "description": "Firefox extension for routing selected sites through a configured proxy.",
  "browser_specific_settings": {
    "gecko": {
      "id": "proxy-browser@local",
      "strict_min_version": "91.1.0"
    }
  },
  "permissions": [
    "proxy",
    "storage",
    "tabs",
    "activeTab",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "src/background.js"
    ]
  },
  "browser_action": {
    "default_title": "Proxy Browser",
    "default_popup": "src/popup/popup.html"
  }
}
